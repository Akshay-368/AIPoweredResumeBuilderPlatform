{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "auth-route": {
        "ClusterId": "auth-cluster",
        "Match": {
          "Path": "/api/auth/{**remainder}"
        }
      },
      "users-route": {
        "ClusterId": "auth-cluster",
        "Match": {
          "Path": "/api/users/{**remainder}"
        }
      },
      "parser-route": {
        "ClusterId": "parser-cluster",
        "AuthorizationPolicy": "ParseResumePolicy",
        "Match": {
          "Path": "/api/parser/{**remainder}"
        }
      },
      "ats-route": {
        "ClusterId": "ats-cluster",
        "Match": {
          "Path": "/api/ats/{**remainder}"
        }
      },
      "projects-route": {
        "ClusterId": "ats-cluster",
        "Match": {
          "Path": "/api/projects/{**remainder}"
        }
      },
      "notifications-route": {
        "ClusterId": "ats-cluster",
        "Match": {
          "Path": "/api/notifications/{**remainder}"
        }
      },
      "feedback-route": {
        "ClusterId": "ats-cluster",
        "Match": {
          "Path": "/api/feedback/{**remainder}"
        }
      },
      "admin-notifications-route": {
        "ClusterId": "ats-cluster",
        "Match": {
          "Path": "/api/admin/notifications/{**remainder}"
        }
      },
      "admin-route": {
        "ClusterId": "auth-cluster",
        "Match": {
          "Path": "/api/admin/{**remainder}"
        }
      }
    },
    "Clusters": {
      "auth-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5196" 
          }
        }
      },
      "parser-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5111"
          }
        }
      },
      "ats-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5050"
          }
        }
      }
    }
  }
}